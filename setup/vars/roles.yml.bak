    version: '1.21.2'
    scm: git
  - name: poudriere
    galaxy: vbotka.freebsd_poudriere
    src: https://github.com/vbotka/ansible-freebsd-poudriere
    version: '1.3.1'
    scm: git
  - name: redis
    galaxy: vbotka.freebsd_redis
    src: https://github.com/vbotka/ansible-freebsd-redis
    version: '1.4.1'
    scm: git
  - name: ssmtp
    galaxy: vbotka.freebsd_ssmtp
    src: https://github.com/vbotka/ansible-freebsd-ssmtp
    version: '1.4.1'
    scm: git
  - name: timezone
    galaxy: vbotka.freebsd_timezone
    src: https://github.com/vbotka/ansible-freebsd-timezone
    version: '1.6.1'
    scm: git
  - name: wpa_cli
    galaxy: vbotka.freebsd_wpa_cli
    src: https://github.com/vbotka/ansible-freebsd-wpa-cli
    version: '1.5.1'
    scm: git
  - name: zfs
    galaxy: vbotka.freebsd_zfs
    src: https://github.com/vbotka/ansible-freebsd-zfs
    version: '1.3.1'
    scm: git
  - name: nginx
    galaxy: vbotka.nginx
    src: https://github.com/vbotka/ansible-nginx
    version: '1.5.1'
    scm: git
  - name: nrpe
    galaxy: vbotka.nrpe
    src: https://github.com/vbotka/ansible-nrpe
